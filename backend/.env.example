# Application
APP_NAME=ChronoLegal API
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database (migration-ready; not connected in Phase 1)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chronolegal

# JWT (architecture-ready; not enforced in Phase 1)
SECRET_KEY=change-this-to-a-secure-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
